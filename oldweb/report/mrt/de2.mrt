.count}\r\nเรียน {t_placard.placard_to}"},"Font":"CordiaUPC;9;;","Border":";;;;;;;solid:0,0,0","Brush":"solid:Transparent","TextBrush":"solid:0,0,0","TextOptions":{"WordWrap":true},"Type":"Expression"},"5":{"Ident":"StiText","Name":"Text12","Guid":"acb3e05394b9e872f00a9e5889f243f7","ClientRectangle":"1.2,4.4,3.4,0.4","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"วาระการประชุม"},"Font":"CordiaUPC;;;","Border":";;;;;;;solid:0,0,0","Brush":"solid:Transparent","TextBrush":"solid:0,0,0","Type":"Expression"},"6":{"Ident":"StiText","Name":"Text13","Guid":"b12a8e8165f293f00361ff3b06928815","CanGrow":true,"ClientRectangle":"1.2,7.4,7.6,1","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"ดังนั้น จึงขอเรียนเชิญ {t_placard.placard_to} เข้าร่วมประชุม ตามวันเวลาและสถานที่ดังกล่าวข้างต้นโดยพร้อมเพรียงกันด้วย จักขอบพระคุณยิ่ง"},"Font":"CordiaUPC;;;","Border":";;;;;;;solid:0,0,0","Brush":"solid:Transparent","TextBrush":"solid:0,0,0","TextOptions":{"WordWrap":true},"Type":"Expression"},"7":{"Ident":"StiText","Name":"Text1","Guid":"18682feaeff7f9dfebbd933239ffc13e","ClientRectangle":"1.2,1.4,7.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"ประกาศ {t_placard.companyname}"},"HorAlignment":"Right","Font":"CordiaUPC;9;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"},"8":{"Ident":"StiText","Name":"Text6","Guid":"8b64012e731fc3f24df4721f93e196f1","Printable":false,"ClientRectangle":"1.2,9,3,0.6","Enabled":false,"Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"{t_placard.tdate}"},"Font":"CordiaUPC;9;;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"DataColumn"},"9":{"Ident":"StiStartPointPrimitive","Name":"StartPointPrimitive1","ClientRectangle":"0.2,0.2,0,0","Interaction":{"Ident":"StiInteraction"},"ReferenceToGuid":"b16ec4602f8ac385bf8ce80161484f65"},"10":{"Ident":"StiEndPointPrimitive","Name":"EndPointPrimitive1","ClientRectangle":"9,1