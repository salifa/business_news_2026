{"ReportVersion":"2020.2.1","ReportGuid":"3e8df8360d51597141a767f253b30bee","ReportName":"print_placard","ReportAlias":"placard","ReportFile":"de2.mrt","ReportAuthor":"vnnbiz","ReportDescription":"this is bizs daily news","ReportCreated":"/Date(1477296777000+0700)/","ReportChanged":"/Date(1477296777000+0700)/","EngineVersion":"EngineV2","CalculationMode":"Interpretation","ReportUnit":"Centimeters","AutoLocalizeReportOnRun":true,"Culture":"th","PreviewSettings":268435455,"RefreshTime":30,"Styles":{"0":{"Ident":"StiStyle","Name":"Title1","HorAlignment":"Right","VertAlignment":"Center","Font":";19;;","Border":";193,152,89;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:193,152,89","NegativeTextBrush":"solid:Red","AllowUseBorderSides":false},"1":{"Ident":"StiStyle","Name":"Title2","VertAlignment":"Center","Font":";9;;","Border":";102,77,38;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:102,77,38","NegativeTextBrush":"solid:Red","AllowUseBorderSides":false},"2":{"Ident":"StiStyle","Name":"Header1","VertAlignment":"Center","Font":";19;;","Border":";193,152,89;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:193,152,89","NegativeTextBrush":"solid:Red","AllowUseBorderSides":false},"3":{"Ident":"StiStyle","Name":"Header2","HorAlignment":"Center","VertAlignment":"Center","Font":";12;Bold;","Border":";193,152,89;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:193,152,89","NegativeTextBrush":"solid:Red","AllowUseBorderSides":false},"4":{"Ident":"StiStyle","Name":"Header3","HorAlignment":"Center","VertAlignment":"Center","Font":";9;Bold;","Border":"All;193,152,89;;;;;;solid:Black","Brush":"solid:242,234,221","TextBrush":"solid:193,152,89","NegativeTextBrush":"solid:Red","AllowUseBorderSides":false},"5":{"Ident":"StiStyle","Name":"Data1","VertAlignment":"Center","Font":";9;;","Border":";193,152,89;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:102,77,38","NegativeTextBrush":"solid:Red","AllowUse