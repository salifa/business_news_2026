<?php
require_once __DIR__ . '/../includes/config.php';
require_once __DIR__ . '/../classes/Credit.php';

requireLogin();

$credit = new Credit();
$userEmail = getCurrentUserEmail();

// Get packages
$packages = $credit->getPackages();

// Handle form submission
$error = '';
$success = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['package_id'])) {
    if (!isset($_POST['csrf_token']) || !verifyCsrfToken($_POST['csrf_token'])) {
        $error = 'Invalid request. Please try again.';
    } else {
        $packageId = (int)$_POST['package_id'];
        $result = $credit->createPayment($userEmail, $packageId);
        
        if ($result['success']) {
            setFlash('success', 'สร้างรายการชำระเงินสำเร็จ กรุณาอัปโหลดสลิปการโอนเงิน');
            redirect(BASE_URL . 'user/upload-slip.php?payment_id=' . $result['payment_id']);
        } else {
            $error = $result['message'];
        }
    }
}

// Get user credit balance
$userCredits = $credit->getUserCredits($userEmail);
?>
