		  ],
  "border": [ false, false, false, false ],
              "alignment": 'left',
  },

{END cellblock_grid_c3}
																							{BEGIN cellblock_grid_c}
{
	cellId: 'c',
	col:0,
	row:0,
		
		
	//	dynamic colspan/rowspan

		
						
	
	
	
			"stack": [
		
				
