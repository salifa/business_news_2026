AndTime"},"Alias":"print_date_with_commas","Type":"System.DateTime","InitBy":"Expression"}},"DataSources":{"0":{"Ident":"StiMySqlSource","Name":"t_placard","Alias":"t_placard","Columns":{"0":{"Name":"SUBJECT","Index":-1,"NameInSource":"SUBJECT","Alias":"SUBJECT","Type":"System.String"},"1":{"Name":"companyname","Index":-1,"NameInSource":"companyname","Alias":"companyname","Type":"System.String"},"2":{"Name":"content","Index":-1,"NameInSource":"content","Alias":"content","Type":"System.String"},"3":{"Name":"count","Index":-1,"NameInSource":"count","Alias":"count","Type":"System.String"},"4":{"Name":"id","Index":-1,"NameInSource":"id","Alias":"id","Type":"System.Int32"},"5":{"Name":"meeting place","Index":-1,"NameInSource":"meeting place","Alias":"meeting place","Type":"System.String"},"6":{"Name":"meeting_date","Index":-1,"NameInSource":"meeting_date","Alias":"meeting_date","Type":"System.DateTime"},"7":{"Name":"meeting_time","Index":-1,"NameInSource":"meeting_time","Alias":"meeting_time","Type":"System.DateTime"},"8":{"Name":"name_last","Index":-1,"NameInSource":"name_last","Alias":"name_last","Type":"System.String"},"9":{"Name":"name_prefix","Index":-1,"NameInSource":"name_prefix","Alias":"name_prefix","Type":"System.String"},"10":{"Name":"owner_id","Index":-1,"NameInSource":"owner_id","Alias":"owner_id","Type":"System.String"},"11":{"Name":"placard_date","Index":-1,"NameInSource":"placard_date","Alias":"placard_date","Type":"System.DateTime"},"12":{"Name":"placard_tdate","Index":-1,"NameInSource":"placard_tdate","Alias":"placard_tdate","Type":"System.String"},"13":{"Name":"placard_to","Index":-1,"NameInSource":"placard_to","Alias":"placard_to","Type":"System.String"},"14":{"Name":"position","Index":-1,"NameInSource":"position","Alias":"position","Type":"System.String"},"15":{"Name":"publish","Index":-1,"NameInSource":"publish","Alias":"publish","Type":"System.String"},"16":{"Name":"subject","Index":-1,"NameInSource":"subject","Alias":"subject","Type":"System.String"},"17":{"Name":"tdate","Index":-1,"NameInSource":"tdate","Alias":"tdate","Type":"System.String"}},"NameInSource":"Connection","SqlCommand":"SELECT\r\n\tid,\r\n\towner_id,\r\n\tpublish,\r\n\tsubject,\r\n\tcontent,\r\n\tcompanyname,\r\n\t`count`,\r\n\tplacard_to,\r\n\tmeeting_date,\r\n\tmeeting_time,\r\n\t`meeting place`,\r\n\tplacard_date,\r\n\tname_prefix,\r\n\tname_last,\r\n\t`position`,\r\nconcat (DAY(placard_date),' ',Thaimonth(month(placard_date)) ,' ', (year(placard_date)+543) ) as tdate\r\n\r\nFROM placard where publish ='on' and placard_date = '{print_date}'"}},"Databases":{"0":{"Ident":"StiMySqlDatabase","Name":"Connection","Alias":"Connection","ConnectionStringEncrypted":"49Dna0RR2R3peMncyHghY4te+4NNVlHNb0mhjekB62OBxAfL6EsRqEYV+VhqDfVGjVRxAmdZq93MSeHsaknhP91+aWA="}}},"Pages":{"0":{"Ident":"StiPage","Name":"cover_page","Guid":"4e62f6eaa3ee7e20e923c62cc6940bc2","Interaction":{"Ident":"StiInteraction"},"Border":";;2;;;;;solid:Black","Brush":"solid:Transparent","Components":{"0":{"Ident":"StiPageHeaderBand","Name":"PageHeaderBand2","CanShrink":true,"ClientRectangle":"0,0.4,19,0.8","Interaction":{"Ident":"StiInteraction"},"Border":";;;;;;;solid:Black","Brush":"solid:Transparent","Components":{"0":{"Ident":"StiText","Name":"Text16","Guid":"8bcf3f146423ad696bfce3ea02ee03b0","ClientRectangle":"0,0,5.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"หนังสือพิมพ์ข่าวสารนักบัญชี"},"Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"},"1":{"Ident":"StiText","Name":"Text17","Guid":"5a822c5d05a1b3031d7ae5de8dd32e64","ClientRectangle":"6.6,0,5.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"VNNBIZS.COM"},"HorAlignment":"Center","Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"},"2":{"Ident":"StiText","Name":"Text18","Guid":"1547095329f4bba3661a46930ad602a5","ClientRectangle":"16.6,0,2.2,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"{print_date_with_commas}"},"Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","TextFormat":{"Ident":"StiDateFormatService","StringFormat":"D"},"Type":"Expression"},"3":{"Ident":"StiImage","Name":"Image1","Guid":"fffd331df35a762aaec5607573cc1214","ClientRectangle":"0,0.8,19,5.4","Interaction":{"Ident":"StiInteraction"},"HorAlignment":"Center","Border":";;;;;;;solid:0,0,0","Brush":"solid:Transparent","Stretch":true,"AspectRatio":true,"ImageBytes":"data:image/jpeg;base64,"},"4":{"Ident":"StiText","Name":"Text24","Guid":"8db9e96bba6536b963072fd3861eb689","ClientRectangle":"15,0,1.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"ฉบับวันที่ "},"HorAlignment":"Right","Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"}}},"1":{"Ident":"StiPageFooterBand","Name":"PageFooterBand2","Guid":"08d6179b68280f2423b6b7014a09cd9b","ClientRectangle":"0,26.9,19,0.8","Interaction":{"Ident":"StiInteraction"},"Border":";;;;;;;solid:Black","Brush":"solid:191,191,191","Components":{"0":{"Ident":"StiText","Name":"Text15","Guid":"bb9a930a9169875ecea6a42251165c02","ClientRectangle":"6.8,0.1,5.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"{PageNofMThrough}"},"HorAlignment":"Center","Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"}}},"2":{"Ident":"StiShape","Name":"Shape1","ClientRectangle":"0.2,6.4,18.6,0.2","Interaction":{"Ident":"StiInteraction"},"Brush":"solid:Transparent","Size":3,"ShapeType":{"Ident":"StiHorizontalLineShapeType"}},"3":{"Ident":"StiText","Name":"Text4","ShiftMode":"None","Guid":"891e8d781f0a7b0caeffb4c12e26dd30","CanShrink":true,"ClientRectangle":"9.2,9.4,9.6,12.2","Interaction":{"Ident":"StiInteraction"},"OnlyText":true,"Text":{"Value":"ถึงแม้ว่าในยุคดิจิทัลจะมีการนำเทคโนโลยีมาใช้ในการทำงานต่างๆ มากขึ้น แต่ก็ไม่ได้หมายความว่าเรื่องพวกนี้จะทำให้คนเรียนสายบัญชีตกงานได้นะจ๊ะ เพราะพวกเขามีทักษะที่แม้แต่เทคโนโลยีอย่าง AI ก็ทำแทนไม่ได้! จะมีอะไรกันบ้าง? ไปดูกัน\r\n\r\nการวิเคราะห์ข้อมูล\r\n\r\nนอกจากจะต้องรู้เรื่องข้อมูลตัวเลขแล้ว นักบัญชีก็ยังต้องสามารถวิเคราะห์ข้อมูลต่างๆ เพื่อนำไปใช้ในการตัดสินใจ ชี้จุดแข็งจุดอ่อน หรือใช้ในการวางแผนสร้างกลยุทธ์ให้เกิดประโยชน์กับองค์กร\r\n\r\nการให้คำปรึกษา\r\n\r\nทักษะการให้คำปรึกษาใครว่าไม่สำคัญ? แน่นอนว่านักบัญชีจะต้องมีการให้คำแนะนำหรือปรึกษาผู้ประกอบการในด้านต่างๆ ไม่ว่าจะเป็นการวางระบบบัญชี การบริหารงาน จนถึงเรื่องของภาษี\r\n\r\nการปรับตัวใช้เทคโนโลยี\r\n\r\nนักบัญชีที่เก่งจะนำเทคโนโลยีมาใช้เป็นเครื่องมือที่ช่วยให้การทำงานสะดวกขึ้น หรือช่วยในการลดเวลาการทำงานที่ไม่จำเป็น การมีทักษะในการปรับตัวกับเทคโนโลยีต่างๆ เป็นเรื่องที่สำคัญมากๆ\r\n\r\nความเชี่ยวชาญเฉพาะทาง\r\n\r\nนอกจากความรู้เรื่องของบัญชีแล้ว การมีทักษะพิเศษในด้านอื่นๆ ก็ถือเป็นสิ่งจำเป็นอย่างมากในยุคดิจิทัล เพราะจะทำให้เราได้เปรียบในการทำงานกว่าคนที่มีความรู้แค่ด้านบัญชีอย่างเดียว เช่น ทักษะการลงทุน การบริหารองค์กร กฎหมาย ธุรกิจออนไลน์\r\n\r\nสิ่งที่สำคัญที่สุดคือการไม่หยุดพัฒนาตัวเอง และคอยเรียนรู้สิ่งใหม่อยู่เสมอ จะทำให้เราอยู่ในยุคดิจิทัลได้อย่างสบายแน่นอน!\r\n\r\nติดตามข่าวสาร กิจกรรมและข้อมูลของคณะบัญชี : www.spu.ac.th/fac/account/\r\n\r\n"},"Font":"CordiaUPC;12;;","Border":";;;;;;;solid:Black","Brush":"solid:222,235,246","TextBrush":"solid:Black","TextOptions":{"WordWrap":true},"Margins":{"Left":3,"Right":3,"Top":3,"Bottom":3},"ShrinkFontToFitMinimumSize":5,"Type":"Expression"},"4":{"Ident":"StiText","Name":"Text19","Guid":"760624231f1385083aecac07ec42908d","ClientRectangle":"9.2,6.8,9.6,2.4","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"=== สารบัญ ===\r\nข่าวสารเพื่อนักบัญชี  --------------------- หน้า   1\r\nประกาศข่าวสารบริษัทจดทะเบียน ------ หน้า   2...\r\nแนบท้ายใบอณุญาต  --------------------- สุดท้าย"},"HorAlignment":"Center","Font":"CordiaUPC;12;;","Border":"All;;;Dash;;;;solid:0,0,0","Brush":"solid:222,235,246","TextBrush":"solid:Black","TextOptions":{"WordWrap":true},"Margins":{"Left":3,"Right":3,"Top":3,"Bottom":3},"Type":"Expression"},"5":{"Ident":"StiImage","Name":"Image3","Guid":"91275ca00ab77671b74fe9bb5115bd51","ClientRectangle":"14.6,21.8,4.4,4.8","Interaction":{"Ident":"StiInteraction"},"HorAlignment":"Center","Border":";;;;;;;solid:0,0,0","Brush":"solid:Transparent","Stretch":true,"AspectRatio":true,"ImageBytes":"data:image/jpeg;base64,"},"6":{"Ident":"StiText","Name":"Text11","Guid":"c53d5dcb652f95c343ff67fa2b595eb1","ClientRectangle":"0.2,21.8,13.8,4.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"ดีเดย์ 1 กุมภาพันธ์ 2564\r\n🎉🎉บอกต่อ ไม่รอช้า  ผู้ประกอบการรายใหม่ที่เริ่มทำธุรกิจ กรมสรรพากรมีบริการใหม่ สะดวกมากขึ้น บริการเบ็ดเสร็จตั้งแต่เริ่มต้น   \r\n\r\n🔵 จดทะเบียนนิติบุคคลใหม่\r\n🔵 จด VAT\r\n🔵 สมัครใช้บริการ e-Filing กรมสรรพากร\r\n\r\nพร้อมกันแล้วที่กรมพัฒนาธุรกิจการค้า หรือที่สำนักงานพาณิชย์จังหวัดทั่วประเทศ \r\nศึกษาเพิ่มเติม >>https://bit.ly/3a9iurR \r\n\r\nไม่ต้องเสี่ยงเดินทางให้ติดเชื้อ อยู่ห่าง อย่างเป็นห่วง 😀❤️\r\n\r\n#สมัครeFiling #จดVat #จดนิติบุคคล #DBD #กรมสรรพากร"},"Font":"CordiaUPC;11;;","Border":"All;;;None;;;;solid:0,0,0","Brush":"solid:222,235,246","TextBrush":"solid:Black","TextOptions":{"WordWrap":true},"Margins":{"Left":3,"Right":3,"Top":3,"Bottom":3},"Type":"Expression"},"7":{"Ident":"StiText","Name":"Text27","Guid":"89dc6e9e2a1f4b2c0bb6a4e227a56fbf","ClientRectangle":"0.2,6.8,8.8,14.8","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"จัดสัมมนา เรื่อง“Update มาตรฐานการบัญชีสำหรับกิจการที่ไม่มีส่วนได้เสียสาธารณะ (NPAE) และมาตรการผ่อนปรนในช่วง Covid19\" ในครั้งนี้ มีวัตถุประสงค์เพื่อให้ผู้ประกอบการวิชาชีพบัญชีและผู้ที่เกี่ยวข้อง ได้ทราบถึงประเด็นสำคัญของมาตรฐานการรายงานทางการเงินNPAEได้ดียิ่งขึ้น เพื่อเตรียมความพร้อมและปรับเปลี่ยนตามหลักเกณฑ์ใหม่ให้ถูกต้องรวมถึงสร้างความเข้าใจในมาตรการผ่อนปรนในช่วง Covid19 ด้วย สวัสดิการกรมพัฒนาธุรกิจการค้า จึงเห็นควรให้มีการจัดการอบรมครั้งนี้ขึ้น โดยได้เรียนเชิญวิทยากรผู้ทรงคุณวุฒิที่มากด้วยประสบการณ์ในเรื่องนี้มาร่วมพูดคุยให้ความรู้ความเข้าใจ พร้อมถาม/ตอบประเด็นสำคัญของมาตรฐานรายงานทางการเงิน วันที่จัดสัมมนา วันอังคารที่ 30 มีนาคม 2564 สถานที่จัดสัมมนา ณ โรงแรมแอมบาสซาเดอร์ สุขุมวิท 11 กรุงเทพมหานคร ผู้สนใจเข้าร่วมสัมมนา กรุณาสำรองที่นั่งด้วยการกรอกใบสมัคร ตามแบบฟอร์มที่กำหนดพร้อมทั้งชำระค่าธรรมเนียมผ่านธนาคาร จำนวน 1,000 บาท เข้าบัญชีสวัสดิการกรมพัฒนาธุรกิจการค้า ณ ธนาคารกรุงไทย ทุกสาขา การสัมมนา “Update มาตรฐานการบัญชีสำหรับกิจการที่ไม่มีส่วนได้เสียสาธารณะ (NPAE) และมาตรการผ่อนปรนในช่วง Covid19\" สามารถนับชั่วโมงการพัฒนาความรู้ต่อเนื่องทางวิชาชีพของผู้ทำบัญชีและผู้สอบบัญชีรับอนุญาต (อยู่ระหว่างการพิจารณาอนุมัติจากสภาวิชาชีพบัญชีฯ) หากท่านสนใจสมัครเข้าร่วมอบรมให้คลิกได้ที่ https://www.dbd.go.th/download/article/article_20210310104546.pdf *** ท่านสามารถสอบถามรายละเอียดเพิ่มเติมได้ที่ 0 2547 4486 ในวันและเวลาราชการ ***"},"Font":"CordiaUPC;13;;","Border":";;;;;;;solid:0,0,0","Brush":"solid:222,235,246","TextBrush":"solid:0,0,0","TextOptions":{"WordWrap":true},"Type":"Expression"}},"PageWidth":21,"PageHeight":29.7,"Watermark":{"TextBrush":"solid:50,0,0,0"},"Margins":{"Left":1,"Right":1,"Top":1,"Bottom":1}},"1":{"Ident":"StiPage","Name":"placard","Guid":"366bfdc35bcf48f3aeb38f2b5f58db21","Interaction":{"Ident":"StiInteraction"},"Border":";;2;;;;;solid:Black","Brush":"solid:Transparent","Components":{"0":{"Ident":"StiPageHeaderBand","Name":"PageHeaderBand1","ClientRectangle":"0,0.4,19,0.6","Interaction":{"Ident":"StiInteraction"},"Border":";;;;;;;solid:Black","Brush":"solid:Transparent","Components":{"0":{"Ident":"StiText","Name":"Text2","Guid":"837977d9b032af13db18695543556180","ClientRectangle":"0,0,5.4,0.6","Interaction":{"Ident":"StiInteraction"},"Text":{"Value":"หนังสือพิมพ์ข่าวสารนักบัญชี"},"Font":"CordiaUPC;12;Bold;","Border":";;;;;;;solid:Black","Brush":"solid:Transparent","TextBrush":"solid:Black","Type":"Expression"},"1":{"Ident":"StiText","Name":"Text8","Guid":"af357690ee6d49d57e2bc936485d18bb","ClientRectangle":"6.6,0,5