<?php
require_once __DIR__ . '/../../includes/config.php';
require_once __DIR__ . '/../../includes/database.php';

// Get filter and pagination
$year = isset($_GET['year']) ? (int)$_GET['year'] : date('Y');
$month = isset($_GET['month']) ? (int)$_GET['month'] : null;
$page = isset($_GET['page']) ? max(1, (int)$_GET['page']) : 1;
$perPage = 24; // Show 24 newspapers per page
$offset = ($page - 1) * $perPage;

// Get database instance
$db = Database::getInstance();

// Build query
$whereClause = "WHERE status = 'published'";
$params = [];

if ($year) {
    $whereClause .= " AND YEAR(newspaper_date) = :year";
    $params[':year'] = $year;
}

if ($month) {
    $whereClause .= " AND MONTH(newspaper_date) = :month";
    $params[':month'] = $month;
}

// Get total count
$countSql = "SELECT COUNT(*) as total FROM newspapers {$whereClause}";
$countResult = $db->queryOne($countSql, $params);
$totalNewspapers = $countResult['total'] ?? 0;
$totalPages = ceil($totalNewspapers / $perPage);

// Get newspapers
$sql = "SELECT * FROM newspapers 
        {$whereClause} 
        ORDER BY newspaper_date DESC 
        LIMIT {$perPage} OFFSET {$offset}";
$newspapers = $db->query($sql, $params);

// Get available years
$yearsSql = "SELECT DISTINCT YEAR(newspaper_date) as year 
             FROM newspapers 
             WHERE status = 'published' 
             ORDER BY year DESC";
$availableYears = $db->query($yearsSql);

$thaiMonths = [
    1 => 'มกราคม', 2 => 'กุมภาพันธ์', 3 => 'มีนาคม', 4 => 'เมษายน',
    5 => 'พฤษภาคม', 6 => 'มิถุนายน', 7 => 'กรกฎาคม', 8 => 'สิงหาคม',
    9 => 'กันยายน', 10 => 'ตุลาคม', 11 => 'พฤศจิกายน', 12 => 'ธันวาคม'
];
?>
