<?php
require_once __DIR__ . '/../includes/config.php';
require_once __DIR__ . '/../classes/Advertisement.php';

requireAdmin();

$ad = new Advertisement();

// Handle actions
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!isset($_POST['csrf_token']) || !verifyCsrfToken($_POST['csrf_token'])) {
        setFlash('error', 'Invalid request');
    } else {
        $adId = (int)$_POST['ad_id'];
        $action = $_POST['action'];
        
        if ($action === 'approve') {
            $result = $ad->approve($adId, getCurrentUserEmail());
            
            if ($result['success']) {
                // If PDF was generated, show enhanced message with link
                if (isset($result['pdf_generated']) && $result['pdf_generated']) {
                    $downloadLink = BASE_URL . 'public/download.php';
                    $issuesLink = BASE_URL . 'admin/issues.php';
                    $message = $result['message'] . 
                               ' <br><br><strong>หนังสือพิมพ์ PDF พร้อมดาวน์โหลดแล้ว!</strong>' .
                               '<br><a href="' . $downloadLink . '" class="btn btn-sm btn-success mt-2" target="_blank">' .
                               '<i class="fas fa-download"></i> ดูหน้าดาวน์โหลด</a> ' .
                               '<a href="' . $issuesLink . '" class="btn btn-sm btn-primary mt-2">' .
                               '<i class="fas fa-newspaper"></i> จัดการฉบับ PDF</a>';
                    setFlash('success', $message);
                } else {
                    setFlash('success', $result['message']);
                }
            } else {
                setFlash('error', $result['message']);
            }
        } elseif ($action === 'reject') {
            $reason = sanitize($_POST['reason']);
            $result = $ad->reject($adId, getCurrentUserEmail(), $reason);
            
            if ($result['success']) {
                setFlash('success', $result['message']);
            } else {
                setFlash('error', $result['message']);
            }
        }
        
        redirect(BASE_URL . 'admin/manage-advertisements.php');
    }
}

// Get all advertisements
$filter = isset($_GET['filter']) ? sanitize($_GET['filter']) : 'approved';  // Default to approved since ads are auto-approved
$page = isset($_GET['page']) ? max(1, (int)$_GET['page']) : 1;
$advertisements = $ad->getAdvertisements($filter, $page, 20);
$pendingCount = $ad->countPendingAdvertisements();
$stats = $ad->getStatistics();
?>
