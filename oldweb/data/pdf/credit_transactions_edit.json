	col:0,
	row:0,
		
		
	//	dynamic colspan/rowspan

		
						
	
	
	
			"stack": [
		
				
			{"text":[{"text":"{$jslabel credit_transactions package }","bold":true}," ",{$package_pdfvalue}],"hidden":"{$item_hide_integrated_edit_field1}"},
				
				
			{"text":[{"text":"{$jslabel credit_transactions amouth }","bold":true}," ",{$amouth_pdfvalue}],"hidden":"{$item_hide_integrated_edit_field2}"},
				
				
